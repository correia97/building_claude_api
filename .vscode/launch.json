{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C#: csharp Debug",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/csharp/csharp.csproj"
        },
        {
            "name": "GoLang Debugger: Current File",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${file}",
            "showLog": true,
            "cwd": "${workspaceFolder}/src/go/",
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/src/python/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}/src/python/",
            "env": {
                "VIRTUAL_ENV": "${workspaceFolder}/src/python/.venv",
                "PATH": "${workspaceFolder}/src/python/.venv/Scripts;${env:PATH}"
            }
        }
    ]
}